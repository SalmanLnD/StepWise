{
  "installCommand": "npm install --prefix backend && npm install --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{backend/**,node_modules/web-tree-sitter/**,node_modules/tree-sitter-wasms/**,backend/node_modules/web-tree-sitter/**,backend/node_modules/tree-sitter-wasms/**}"
    }
  }
}
